public class arraysss {
    public static void main (String[] args){
        int arr[] ={1,5,6,7,8,10};
        int n = arr.length;
        int temp =0;
        int i=0,j=n-1;

        while (i<=j){
             temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            i++;
            j--;
        }

        for(int ele : arr){
            System.out.print(ele +" ");
        }

    }

}
